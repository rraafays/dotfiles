#!/usr/bin/env bash

sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep -v "^SSH" || echo "")

selected=$(echo "$sessions" | fzf --reverse --prompt="attach: " --preview "$HOME/.config/tmux/preview {}" --preview-window=right:50% --print-query | tail -1)

if [ -z "$selected" ]; then
    exit 0
fi

if tmux has-session -t "$selected" 2>/dev/null; then
    tmux switch-client -t "$selected"
else
    tmux new-session -d -s "$selected" && tmux switch-client -t "$selected"
fi
