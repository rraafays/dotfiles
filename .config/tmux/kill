#!/usr/bin/env bash

sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null || echo "")

if [ -z "$sessions" ]; then
    echo "No tmux sessions found."
    exit 0
fi

selected=$(echo "$sessions" | fzf --reverse --prompt="kill: " --preview "$HOME/.config/tmux/preview {}" --preview-window=right:50% --print-query | tail -1)

if [ -z "$selected" ]; then
    exit 0
fi

if tmux has-session -t "$selected" 2>/dev/null; then
    tmux kill-session -t "$selected"
else
    exit 1
fi
