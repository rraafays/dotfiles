#!/bin/bash

if [ -z "$1" ]; then
    echo "Error: No session name provided"
    echo "Usage: tmux-session-preview.sh <session-name>"
    exit 1
fi

session="$1"
echo "$session"
echo ""

windows=$(tmux list-windows -t "$session" -F "#{window_index}" 2>/dev/null)

for window in $windows; do
    pane_count=$(tmux list-panes -t "$session":"$window" 2>/dev/null | wc -l)

    if [ "$pane_count" -eq 1 ]; then
        tmux list-panes -t "$session":"$window" -F "  ▸ #{pane_current_command} [#{pane_pid}]: #{pane_current_path}" 2>/dev/null
    else
        echo "  ▸ $pane_count panes"
        panes=$(tmux list-panes -t "$session":"$window" -F "#{pane_index}" 2>/dev/null)
        last_pane=$(echo "$panes" | tail -1)
        for pane in $panes; do
            if [ "$pane" = "$last_pane" ]; then
                tmux display-message -p -t "$session":"$window"."$pane" -F "    └─ #{pane_current_command} [#{pane_pid}]: #{pane_current_path}" 2>/dev/null
            else
                tmux display-message -p -t "$session":"$window"."$pane" -F "    ├─ #{pane_current_command} [#{pane_pid}]: #{pane_current_path}" 2>/dev/null
            fi
        done
    fi
done
